# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_WEBAPP_URL=https://your-domain.com

# Database
DATABASE_URL=sqlite+aiosqlite:///./vetai.db

# HuggingFace Inference API
HF_API_TOKEN=hf_your_token_here
HF_CHAT_MODEL=Qwen/Qwen2.5-7B-Instruct
HF_VISION_MODEL=Qwen/Qwen2.5-VL-72B-Instruct
HF_PROVIDER=together
HF_VISION_PROVIDER=hyperbolic

# Yandex Cloud S3
S3_ENDPOINT=https://storage.yandexcloud.net
S3_BUCKET=vetai-uploads
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key

# OCR engine: paddleocr | tesseract
OCR_ENGINE=paddleocr

# Frontend
VITE_API_URL=http://localhost:8000